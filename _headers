# 所有页面和 API 禁止缓存
*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# 静态资源缓存 7 天
/assets/*
  Cache-Control: public, max-age=604800, immutable

/pwa-icon.svg
  Cache-Control: public, max-age=604800, immutable

# 提示词数据缓存 1 天
/prompts_data.json
  Cache-Control: public, max-age=86400
